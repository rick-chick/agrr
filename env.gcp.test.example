# Copy to .env.gcp.test — merge OAuth etc. from .env.gcp when deploying.
PROJECT_ID=agrr-475323
REGION=asia-northeast1
SERVICE_NAME=agrr-test
GCS_BUCKET=agrr-test-db
IMAGE_NAME=agrr-test
WEATHER_DATA_STORAGE=gcs
GCS_WEATHER_DATA_BUCKET=agrr-weather-data
USE_AGRR_DAEMON=true
ALLOWED_HOSTS=agrr-test.net,www.agrr-test.net,.run.app
# RAILS_MASTER_KEY / SECRET_KEY_BASE — see env.gcp.example

# Local UI (ng serve --configuration gcp-test) — also set in Google OAuth redirect URIs
FRONTEND_URL=http://127.0.0.1:4201,http://localhost:4201
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:4201/auth/google_oauth2/callback

