# Environment Variables Configuration
# Copy this file to .env and update the values for your environment

# ==========================================
# Rails Configuration
# ==========================================
RAILS_ENV=development
# Generate master key with: rails secret
RAILS_MASTER_KEY=your_master_key_here

# ==========================================
# App Runner Configuration
# ==========================================
# Add your App Runner service URL (comma-separated if multiple)
ALLOWED_HOSTS=your_app_runner_url_here

# ==========================================
# Google OAuth Configuration
# ==========================================
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Angular dev (ng serve :4200 + proxy) / 本番 SPA の origin（カンマ区切り可）。Rust の return_to 許可と OAuth callback 導出に使用
FRONTEND_URL=http://127.0.0.1:4200,http://localhost:4200
# Optional: 未設定時は FRONTEND_URL 先頭 origin + /auth/google_oauth2/callback（agrr-server）
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:4200/auth/google_oauth2/callback

# ==========================================
# Optional: Rails Settings
# ==========================================
RAILS_MAX_THREADS=5
RAILS_LOG_LEVEL=info
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# Use Bootsnap cache in read-only mode (recommended for production containers)
# BOOTSNAP_READONLY=1

# ==========================================
# Google Ads / コンバージョン トラッキング（任意）
# ==========================================
# Google 広告の「コンバージョンアクション」で取得するタグ ID（例: AW-123456789）
# - Cloud Run（Rails）: サーバー側レンダの gtag に `gtag('config', AW-…)` を載せるために使用
GOOGLE_ADS_CONVERSION_ID=

# フロント静的デプロイ (.env.gcp.frontend) で index.html に注入し、
# OAuth / モックログイン直後の転換イベントに使う send_to（例: AW-123456789/AbCd）
# 空のままならコンバージョン ping は送らず、タグのみ（AW config）の状態。
GOOGLE_ADS_LOGIN_CONVERSION_SEND_TO=

# ==========================================
# agrr daemon (development)
# ==========================================
# ローカル / Docker 開発で最適化・天気予測に実 agrr を使う（推奨）
# USE_AGRR_DAEMON=true
# AGRR_BIN_PATH=./lib/core/agrr
# 予測だけモックに戻す場合のみ: AGRR_USE_MOCK=true

# ==========================================
# Weather Data Source Configuration
# ==========================================
# Options: nasa-power (default, global coverage), openmeteo, jma (Japan only), noaa-ftp (US)
# NASA POWER: Global grid-based data (1984-present), ideal for India and worldwide coverage
WEATHER_DATA_SOURCE=nasa-power

# Weather Data Storage: active_record (SQLite) or gcs (Cloud Storage JSON files)
# Production: gcs (see env.gcp.example). Development default: active_record
# Local check (isolated DB, active_record): scripts/verify-weather-sqlite-local.sh
WEATHER_DATA_STORAGE=active_record
# GCS_WEATHER_DATA_BUCKET=your-weather-data-bucket
# Or use existing GCS_BUCKET (weather_data/ prefix will be used)

# ==========================================
# Google Cloud Storage Configuration (for Litestream)
# ==========================================
# GCS bucket for Litestream database replication
# Production environment uses GCS_BUCKET (set in env.gcp.example)
# Development environment uses GCS_BUCKET_DEV (separate bucket to avoid conflicts)
GCS_BUCKET_DEV=agrr-development-db

# ==========================================
# Notes:
# ==========================================
# - SQLite databases are stored in ./storage/ directory
# - No PostgreSQL or Redis needed (using SQLite + Solid Queue/Cache)
# - For production, ensure ./storage/ is mounted to persistent EFS volume
