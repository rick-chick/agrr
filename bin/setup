#!/usr/bin/env bash
# Development setup (idempotent). DB schema via agrr-migrate — not rails db:prepare.
# Full reference masters: .cursor/skills/dev-docker/scripts/load-reference-data-host.sh
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

export AGRR_SQLITE_PATH="${AGRR_SQLITE_PATH:-$ROOT/storage/development.sqlite3}"
export AGRR_CACHE_SQLITE_PATH="${AGRR_CACHE_SQLITE_PATH:-$ROOT/storage/development_cache.sqlite3}"

echo "== Installing Ruby dependencies (Rails shell / contract harness) =="
if [ -f Gemfile ]; then
  gem install bundler --conservative
  bundle check || bundle install
fi

echo ""
echo "== Preparing database (agrr-migrate schema) =="
"${ROOT}/scripts/run-agrr-migrate.sh" schema run

echo ""
echo "== Done =="
echo "  Primary DB:  ${AGRR_SQLITE_PATH}"
echo "  Cache DB:    ${AGRR_CACHE_SQLITE_PATH}"
echo ""
echo "Reference masters (JP/IN/US) are not loaded by setup alone."
echo "  Docker: .cursor/skills/dev-docker/scripts/load-reference-data.sh"
echo "  Host:   .cursor/skills/dev-docker/scripts/load-reference-data-host.sh"
echo ""
echo "Start API: .cursor/skills/dev-docker/scripts/up.sh"
echo "           or host-rust-stack.sh"
