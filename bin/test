#!/bin/bash

# AGRR: テスト実行（開発 DB 保護のため専用コンテナ / スクリプト経由のみ）
# 本番 API 振る舞いの正: scripts/run-rust-contract-tests.sh（R4, CONTRACT_RUNTIME=rust）
# R4 contract: run-rust-contract-tests.sh（P8.6 — Ruby 契約なし）

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

if [ $# -eq 0 ]; then
    echo "🧪 AGRR テスト実行スクリプト"
    echo ""
    echo "使用方法:"
    echo "  ./bin/test                              # 全体（cargo + R4）"
    echo "  ./bin/test                              # 引数付きも R4 一式（Ruby 契約廃止）"
    echo ""
    echo "💡 直接 'rails test' は開発 DB 破壊防止のため拒否されます"
    echo "💡 API/WS の正は R4: scripts/run-rust-contract-tests.sh"
    echo ""
fi

if [ $# -eq 0 ]; then
  if command -v cargo >/dev/null 2>&1 || [ -f "${HOME}/.cargo/env" ]; then
    echo ""
    echo "🚀 agrr-domain（cargo test）を実行します..."
    AGRR_TEST_SCRIPT=1 "$PROJECT_ROOT/.cursor/skills/test-common/scripts/run-test-rust-domain.sh"
    echo ""
    echo "🚀 R4 contract（本番経路の正, CONTRACT_RUNTIME=rust）..."
    AGRR_TEST_SCRIPT=1 "$PROJECT_ROOT/scripts/run-rust-contract-tests.sh"
  else
    echo ""
    echo "⏭️  cargo 未インストールのため agrr-domain / R4 をスキップ（CI: rust-domain-test workflow）"
  fi
else
  AGRR_TEST_SCRIPT=1 "$PROJECT_ROOT/.cursor/skills/test-common/scripts/run-test-rails.sh" "$@"
fi
