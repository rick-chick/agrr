#!/usr/bin/env ruby
# frozen_string_literal: true

# 参照農場の天気データ取得スクリプト（JMA版）
#
# 使用方法:
#   bin/fetch_reference_weather_data                           # 全参照農場の天気データを取得
#   bin/fetch_reference_weather_data --farm-name "北海道"       # 特定の農場のみ
#
# 前提条件:
#   - agrr-migrate data apply 済み（参照農場がDBに存在する）
#   - agrrバイナリが lib/core/agrr に存在する
#
# 処理内容:
#   1. DBから参照農場を取得
#   2. 各農場について agrrコマンドを実行してJMAから天気データを取得
#   3. 取得したデータをdb/fixtures/reference_weather.json に保存

require 'fileutils'
require 'json'
require 'open3'

require_relative '../config/environment'

# ログ出力用のカラー定義
class ColorLogger
  COLORS = {
    red: "\e[31m",
    green: "\e[32m",
    yellow: "\e[33m",
    blue: "\e[34m",
    reset: "\e[0m"
  }

  def self.log(message, color = :reset)
    puts "#{COLORS[color]}#{message}#{COLORS[:reset]}"
  end

  def self.info(message)
    log("ℹ️  #{message}", :blue)
  end

  def self.success(message)
    log("✅ #{message}", :green)
  end

  def self.warning(message)
    log("⚠️  #{message}", :yellow)
  end

  def self.error(message)
    log("❌ #{message}", :red)
  end
end

# agrr daemon clientでJMAから天気データを取得
def fetch_weather_from_jma(latitude, longitude)
  agrr_client_path = Rails.root.join('bin', 'agrr_client').to_s
  
  unless File.exist?(agrr_client_path)
    ColorLogger.error("agrr clientが見つかりません: #{agrr_client_path}")
    return nil
  end
  
  # 2000年1月1日から今日までのデータを取得
  start_date = Date.new(2000, 1, 1)
  end_date = Date.today
  
  command = [
    agrr_client_path,
    'weather',
    '--location', "#{latitude},#{longitude}",
    '--start-date', start_date.to_s,
    '--end-date', end_date.to_s,
    '--data-source', 'jma',
    '--json'
  ]
  
  ColorLogger.info("実行コマンド: #{command.join(' ')}")
  
  stdout, stderr, status = Open3.capture3(*command)
  
  unless status.success?
    ColorLogger.error("agrrコマンドが失敗しました: #{stderr}")
    return nil
  end
  
  JSON.parse(stdout)
rescue JSON::ParserError => e
  ColorLogger.error("JSON解析エラー: #{e.message}")
  nil
rescue => e
  ColorLogger.error("天気データ取得エラー: #{e.message}")
  nil
end

# オプション解析
farm_name_filter = nil

ARGV.each_with_index do |arg, i|
  case arg
  when '--farm-name'
    farm_name_filter = ARGV[i + 1] if ARGV[i + 1]
  end
end

# ヘッダー
ColorLogger.log("\n" + "=" * 60, :blue)
ColorLogger.log("参照農場の天気データ取得スクリプト（JMA版）", :blue)
ColorLogger.log("=" * 60, :blue)
puts ""

# 1. DBから参照農場を取得
ColorLogger.info("参照農場を検索中...")
farms = Farm.where(is_reference: true)
farms = farms.where(name: farm_name_filter) if farm_name_filter

if farms.empty?
  ColorLogger.error("参照農場が見つかりません。先に load-reference-data-host.sh または agrr-migrate data apply を実行してください。")
  exit 1
end

ColorLogger.success("#{farms.count}件の参照農場を発見しました")
puts ""

# 2. 各農場の天気データを取得
output = {}

farms.each_with_index do |farm, index|
  ColorLogger.log("\n[#{index + 1}/#{farms.count}] 処理中: #{farm.name}", :blue)
  puts "  位置: #{farm.latitude}, #{farm.longitude}"
  
  # JMAから天気データを取得（2000年1月1日〜今日まで）
  weather_result = fetch_weather_from_jma(farm.latitude, farm.longitude)
  
  if weather_result.nil?
    ColorLogger.warning("  データ取得失敗（スキップ）")
    next
  end
  
  # データを変換
  location_data = weather_result['location']
  weather_data_raw = weather_result['data']
  
  if weather_data_raw.nil? || weather_data_raw.empty?
    ColorLogger.warning("  データが空です（スキップ）")
    next
  end
  
  # フォーマット変換
  weather_data = weather_data_raw.map do |daily|
    {
      'date' => daily['time'],
      'temperature_max' => daily['temperature_2m_max'],
      'temperature_min' => daily['temperature_2m_min'],
      'temperature_mean' => daily['temperature_2m_mean'],
      'precipitation' => daily['precipitation_sum'],
      'sunshine_hours' => daily['sunshine_hours'],
      'wind_speed' => daily['wind_speed_10m'],
      'weather_code' => daily['weather_code']
    }
  end
  
  output[farm.name] = {
    'name' => farm.name,
    'latitude' => farm.latitude,
    'longitude' => farm.longitude,
    'is_reference' => farm.is_reference,
    'weather_location' => {
      'latitude' => location_data['latitude'],
      'longitude' => location_data['longitude'],
      'elevation' => location_data['elevation'],
      'timezone' => location_data['timezone']
    },
    'weather_data' => weather_data
  }
  
  ColorLogger.success("  #{weather_data.count}件のデータを取得しました")
end

if output.empty?
  ColorLogger.error("エクスポートするデータがありません")
  exit 1
end

# 3. ファイルに保存
fixture_path = Rails.root.join('db/fixtures/reference_weather.json')
FileUtils.mkdir_p(File.dirname(fixture_path))
File.write(fixture_path, JSON.pretty_generate(output))

puts ""
ColorLogger.log("=" * 60, :green)
ColorLogger.success("完了！")
ColorLogger.log("=" * 60, :green)
puts ""
puts "📄 保存先: #{fixture_path}"
puts "📊 農場数: #{output.keys.count}"
puts "📊 総天気レコード数: #{output.values.sum { |v| v['weather_data'].count }}"
puts ""
ColorLogger.info("次のステップ:")
puts "  1. ファイルを確認: cat #{fixture_path} | head -n 50"
puts "  2. Gitにコミット: git add #{fixture_path}"
puts "  3. 以後は agrr-migrate data apply で参照データを再投入できます"
puts ""
