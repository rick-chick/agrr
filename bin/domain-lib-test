#!/usr/bin/env ruby
# frozen_string_literal: true

# lib/domain のユニットテストを Rails アプリ（config/environment）を起動せずに実行する。
# Usage:
#   bundle exec bin/domain-lib-test
#   bundle exec bin/domain-lib-test test/domain/crop/interactors/crop_list_interactor_test.rb
#   bundle exec bin/domain-lib-test test/domain/crop/

ENV["RAILS_ENV"] ||= "test"

root = File.expand_path("..", __dir__)
Dir.chdir(root)

require File.join(root, "test/support/domain_lib_test_convention.rb")

tests =
  if ARGV.empty?
    DomainLibTestConvention.all_domain_test_paths(root)
  else
    begin
      DomainLibTestConvention.resolve_test_paths(root, ARGV)
    rescue DomainLibTestConvention::MissingPathError => e
      abort "domain-lib-test: 指定されたパスが見つかりません: #{e.entry}"
    rescue DomainLibTestConvention::EmptyDirectoryError => e
      abort "domain-lib-test: 指定ディレクトリに *_test.rb がありません: #{e.entry}"
    end
  end

DomainLibTestConvention.assert_ok!(tests, root: root)

# ruby foo.rb bar.rb は bar を実行しない（ARGV に入るだけ）ため、明示的に load する。
load_script = tests.map { |p| "load(#{p.dump})" }.join("; ")
exec(
  Gem.ruby,
  "-W:deprecated",
  "-I#{root}/lib",
  "-I#{root}/app",
  "-I#{root}/test",
  "-e",
  load_script
)
