# Linux 専用: テキストは LF を正とする（CRLF 混在・autocrlf 弊害を防ぐ）
* text=auto eol=lf

# Ruby は LF を正とする（CRLF 警告・混在を防ぐ）
*.rb text eol=lf

# ロケールファイルは自動マージしない（手動マージ必須）
config/locales/views/farms.*.yml merge=ours
# その他のロケールファイルも保護
config/locales/*.yml merge=ours
# シェルスクリプト
*.sh text eol=lf
*.zip filter=lfs diff=lfs merge=lfs -text
*.json filter=lfs diff=lfs merge=lfs -text
lib/core filter=lfs diff=lfs merge=lfs -text
db/fixtures/*.json filter=lfs diff=lfs merge=lfs -text
*.bak filter=lfs diff=lfs merge=lfs -text
# Docker テスト entrypoint 等が npm で lock を書き換える。LFS ポインタ差分（数千行）を防ぐ。
package-lock.json -filter -diff -merge text eol=lf
frontend/package-lock.json -filter -diff -merge text eol=lf
# Cloud Agent は environment.json を実体 JSON として読む（LFS ポインタ不可）
.cursor/environment.json -filter -diff -merge text eol=lf
