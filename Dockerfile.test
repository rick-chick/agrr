# Test image: R4 contract harness (Minitest + ActiveRecord) + agrr-migrate
FROM ruby:3.3.10-slim AS builder

RUN apt-get update -qq && apt-get install -y \
    build-essential \
    libsqlite3-dev \
    libyaml-dev \
    curl \
    ca-certificates \
    dos2unix \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY Gemfile Gemfile.lock ./
RUN bundle config set --local deployment 'true' && \
    bundle config set --local without 'development' && \
    bundle install

COPY . .
RUN find /app -name "*.rb" -type f -exec dos2unix {} \; 2>/dev/null || true
RUN mkdir -p storage

FROM rust:1-bookworm AS rust_builder
WORKDIR /app
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY crates ./crates
RUN cargo build --release -p agrr-migrate

FROM ruby:3.3.10-slim

RUN apt-get update -qq && apt-get install -y \
    libsqlite3-0 \
    libyaml-0-2 \
    curl \
    ca-certificates \
    build-essential \
    libsqlite3-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app /app
COPY --from=rust_builder /app/target/release/agrr-migrate /usr/local/bin/agrr-migrate
RUN chmod +x /usr/local/bin/agrr-migrate /app/scripts/*.sh 2>/dev/null || true

RUN bundle config set --local deployment 'true' && \
    bundle config set --local without 'development' && \
    bundle install

RUN mkdir -p /app/storage

ENV RAILS_ENV=test
CMD ["bash", "/app/scripts/docker-entrypoint-test.sh"]
