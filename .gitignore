# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Generated at frontend build / deploy (see .cursor/skills/deploy-frontend/scripts/generate-sitemap.mjs).
/frontend/public/sitemap.xml

# Ignore bundler config.
/.bundle

# Ignore all environment files (with override for example files).
/.env
/.env.*
!/.env.example
!/.env.gcp.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/memory_monitoring/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage files.
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore node_modules（任意の階層）
node_modules/

# Ignore databases (they should be generated)
*.sqlite3
*.sqlite3-*

# Ignore uploaded files
/public/uploads

# Ignore test coverage
/coverage

# Ruby / Bundler (inside repo)
/vendor/bundle

# Byebug & RSpec artifacts
/.byebug_history
/.rspec_status
/spec/examples.txt

# direnv
/.envrc
/.direnv/

# Local cookie/session exports
/cookies.txt

# JS package managers debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Docker entrypoints rename host .npmrc here during container npm installs
/.npmrc.bak

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor-specific files (root .vscode: ignore local files except shared watcher policy)
/.vscode/*
!/.vscode/
!/.vscode/settings.json
/.idea
*.swp
*.swo
*~

# Seed backup files (temporary during migration)
db/seeds.rb.backup
db/seeds/**/*.backup

# Schema dumps are generated locally (docker entrypoint removes tracked copies)
db/schema.rb
db/cache_schema.rb
db/cable_schema.rb

# Schema backup during migration refactoring
db/schema.rb.tmp
db/cache_schema.rb.tmp

# AWS CLI (if accidentally extracted)
/aws/

# Memory monitoring logs (keep directory structure)
/tmp/memory_monitoring/*.csv
/tmp/memory_monitoring/*.txt
/tmp/memory_monitoring/*.log

# AGRR debug files (keep directory structure)
/tmp/debug/*
!/tmp/debug/.keep

# Automation tooling outputs (regenerated locally; keep directory)
/automation/output/*
!/automation/output/.keep

# AGRR binary backups (auto-generated)
/lib/core/agrr.backup*
/lib/core/_internal.backup*
/lib/core/agrr.broken
/lib/core/agrr_host

# System test screenshots
/tmp/screenshots/*
!/tmp/screenshots/.keep

# Ignore fixture environment files
/db/fixtures/*.env*
/db/fixtures/*.ya?ml

# Ignore reference data that may contain sensitive information
/db/fixtures/**/*.json
# Weather JSON: fetched via scripts/ensure-reference-fixtures.sh (GCS lock file)
# Crops JSON: small reference masters tracked in Git (LFS until budget restored)
!/db/fixtures/reference_crops.json
!/db/fixtures/us_reference_crops.json
!/db/fixtures/india_reference_crops.json

# Track example files while ignoring actual fixtures
!/db/fixtures/*.example



# Rust / Cargo build artifacts
/target/

tmp/

# Cursor: track agent skills / rules / scripts; ignore local IDE state
.cursor/*
!.cursor/environment.json
!.cursor/references/
!.cursor/references/**
!.cursor/scripts/
!.cursor/scripts/**
!.cursor/skills/
!.cursor/skills/**
!.cursor/rules/
!.cursor/rules/**

.cursor/TODO.md
.cursor/agents/
.cursor/plans/
.cursor/puppeteer-*.js
.cursor/worktrees.json
.cursor/skills_link

.dockerignore
lib/core/agrr
lib/core/_internal
vendor/
