# Google Cloud Project Configuration
PROJECT_ID=agrr-475323
PROJECT_NUMBER=471079631517
REGION=asia-northeast1
SERVICE_NAME=agrr-production

# Cloud Storage
GCS_BUCKET=agrr-production-db

# Weather bulk data (required for production — gcp-deploy.sh / gcp-deploy-rust.sh)
# gcs: weather_data/{location_id}/{year}.json on GCS (uses GCS_BUCKET or GCS_WEATHER_DATA_BUCKET)
# active_record: SQLite only — development default; do not use on agrr-production
WEATHER_DATA_STORAGE=gcs
# Optional dedicated bucket; if unset, WeatherDataGcsHttpGateway uses GCS_BUCKET
# GCS_WEATHER_DATA_BUCKET=agrr-production-db

# Container Registry
REGISTRY=asia-northeast1-docker.pkg.dev
# gcp-deploy.sh / gcp-deploy-rust.sh → agrr-server:YYYYMMDD-HHMMSS
RUST_IMAGE_NAME=agrr-server

# agrr-server (Cloud Run)
AGRR_ENV=production
# SQLite busy timeout (ms). Increase to reduce "database is locked". Default: 20000
# SQLITE_BUSY_TIMEOUT_MS=60000

SECRET_KEY_BASE=8c7ba07b00a6a168df5904131650a12b95e23a9f464084823bd0cf210675f59af3fc4fef9172a927b945cf40ecbef95a72e4f2f884d82b544f27f4cd04f55c74

# Allowed Hosts
ALLOWED_HOSTS=agrr.net,www.agrr.net,.run.app

# Optional: public HTTPS base for production-admin scripts (backdoor API).
# Cloud Run ingress may be load-balancer-only; *.run.app then returns 404.
# If unset, scripts use the first non-wildcard host from ALLOWED_HOSTS.
# PRODUCTION_PUBLIC_URL=https://agrr.net

# Google Ads（任意・コンバージョン トラッキング）
# Google 広告の「Google タグ」ID（AW-…）。Rails の gtag に第2の config として載せる。
# GOOGLE_ADS_CONVERSION_ID=AW-xxxxxxxxxx
# フロント SPA のログイン完了 ping は .env.gcp.frontend の GOOGLE_ADS_LOGIN_CONVERSION_SEND_TO を参照。

# Google OAuth (agrr-server — must match Google Console redirect URIs)
GOOGLE_OAUTH_REDIRECT_URI=https://agrr.net/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

AGRR_BACKDOOR_TOKEN=your_backdoor_token_here

USE_AGRR_DAEMON=true
SQLITE_BUSY_TIMEOUT_MS=60000

# GCP test only (gcp-deploy-rust uses Secret Manager on production)
# SCHEDULER_AUTH_TOKEN=your_scheduler_auth_token_here

# Deploy: .cursor/skills/deploy-server/scripts/gcp-deploy.sh  (→ Dockerfile.agrr-server)
