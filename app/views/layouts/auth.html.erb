<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <%= render "shared/meta_tags" %>
  
  <!-- Bundled CSS (Leaflet など npm パッケージ) - esbuild でビルド -->
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  
  <!-- Core Design System - 必ず最初に読み込む -->
  <%= render_core_stylesheets %>
  
  <!-- Utility CSS classes -->
  <%= render_utility_stylesheets %>
  
  <!-- Components -->
  <%= render_component_stylesheets(components: [
    "components/buttons",
    "components/forms"
  ]) %>
  
  <!-- Auth-specific styles -->
  <%= render_feature_stylesheets(features: ["auth"]) %>
  
  <!-- Bundled JavaScript (includes Leaflet) -->
  <%= render_common_javascripts(include_shared_systems: false) %>
</head>
<body class="auth-body">
  <%= yield %>
  
  <%= yield :javascripts %>
</body>
</html>

