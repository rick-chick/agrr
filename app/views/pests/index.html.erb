<% content_for :title, "#{t('.title')} - AGRR" %>

<div class="page-header">
  <h1 class="page-title"><%= t('.title') %></h1>
</div>

<% if @pests.any? %>
  <div class="crops-grid">
    <% @pests.each do |pest_row| %>
      <% parts = referencable_list_row_parts(pest_row) %>
      <% pest = parts.record %>
      <% display = parts.display %>
      <div class="crop-card" id="pest_<%= pest.id %>" data-undo-delete-record>
        <h3 class="crop-name"><%= pest.name %></h3>
        <% if pest.name_scientific.present? %>
          <div class="crop-variety"><%= pest.name_scientific %></div>
        <% end %>
        <% if display&.show_reference_badge %>
          <div class="crop-type reference"><%= t('.reference_pests') %></div>
        <% end %>
        <div class="crop-actions">
          <%= link_to t('.actions.show'), pest_path(pest.id), class: "btn btn-info btn-sm" %>
          <% if display&.show_delete_button %>
            <%= link_to t('.actions.delete'), pest_path(pest.id),
                        class: "btn btn-error btn-sm",
                        data: {
                          controller: "undo-delete",
                          action: "click->undo-delete#submit",
                          turbo_method: :delete,
                          undo_delete_url_value: pest_path(pest.id),
                          undo_delete_message_value: t('pests.undo.toast', name: pest.name)
                        } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <div class="empty-state-icon"><%= t('.empty.icon') %></div>
    <h3><%= t('.empty.title') %></h3>
    <p><%= t('.empty.description') %></p>
  </div>
<% end %>
