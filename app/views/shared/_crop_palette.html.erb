<%# app/views/shared/_crop_palette.html.erb %>
<%# 作物パレット（サイドパネル） %>
<%#
  A) crop_palette_embed: { used_crop_ids:, crops: } — crops は DTO 等 #id #name #variety
  B) cultivation_plan: AR（レガシー）
%>

<%
  crop_palette_embed = local_assigns[:crop_palette_embed]

  if crop_palette_embed.present?
    used_crop_ids = crop_palette_embed[:used_crop_ids]
    available_crops = crop_palette_embed[:crops]
  else
    cultivation_plan = local_assigns.fetch(:cultivation_plan)
    used_crop_ids = cultivation_plan.cultivation_plan_crops.map { |cpc| cpc.crop&.id }.compact
    if cultivation_plan.plan_type == 'public'
      available_crops = Crop.reference.where(region: cultivation_plan.farm.region).order(:name)
    else
      available_crops = cultivation_plan.user.crops.where(is_reference: false).order(:name)
    end
  end
%>

<%# ドロップダウンコンテナ（栽培スケジュールの右上に配置） %>
<div class="crop-palette-container">
  <%# ドロップダウンボタン %>
  <button class="crop-palette-toggle-btn" id="crop-palette-toggle" aria-label="<%= crop_palette_toggle_label || t('shared.crop_palette.toggle', default: '作物を追加') %>">
    <span class="crop-palette-icon">🌱</span>
    <span class="toggle-text"><%= crop_palette_title || t('shared.crop_palette.title', default: '作物を追加') %></span>
    <span class="toggle-icon">▼</span>
  </button>

  <%# ドロップダウンパネル（初期状態は非表示） %>
  <div class="crop-palette-panel collapsed" id="crop-palette-panel">
    <div class="crop-palette-body">
      <div class="crop-palette-grid">
        <% available_crops.each do |crop| %>
          <% c_id = crop.respond_to?(:id) ? crop.id : crop[:id] %>
          <% c_name = crop.respond_to?(:name) ? crop.name : crop[:name] %>
          <% c_variety = crop.respond_to?(:variety) ? crop.variety : crop[:variety] %>
          <div class="crop-palette-card"
               data-crop-id="<%= c_id %>"
               data-crop-name="<%= c_name %>"
               data-crop-variety="<%= c_variety %>">
            <!-- ガントカードと同じスタイルのバー -->
            <div class="crop-card-bar">
              <span class="crop-card-label"><%= c_name %></span>
              <% if used_crop_ids.include?(c_id) %>
                <span class="crop-card-badge"><%= crop_palette_in_use_label || t('shared.crop_palette.in_use', default: '使用中') %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
