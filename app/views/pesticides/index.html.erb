<% content_for :title, "#{t('.title')} - AGRR" %>

<div class="page-header">
  <h1 class="page-title"><%= t('.title') %></h1>
</div>

<% if @pesticides&.any? %>
  <div class="crops-grid">
    <% @pesticides.each do |pesticide_row| %>
      <% parts = referencable_list_row_parts(pesticide_row) %>
      <% pesticide = parts.record %>
      <% display = parts.display %>
      <div class="crop-card" id="pesticide_<%= pesticide.id %>" data-undo-delete-record>
        <h3 class="crop-name"><%= pesticide.name %></h3>
        <% if pesticide.active_ingredient.present? %>
          <div class="crop-variety"><%= t('.active_ingredient') %>: <%= pesticide.active_ingredient %></div>
        <% end %>
        <% if display&.show_reference_badge %>
          <div class="crop-type reference"><%= t('.reference_pesticides') %></div>
        <% end %>
        <div class="crop-actions">
          <%= link_to t('.actions.show'), pesticide_path(pesticide.id), class: "btn btn-info btn-sm" %>
          <% if display&.show_delete_button %>
            <%= link_to t('.actions.delete'), pesticide_path(pesticide.id),
                        class: "btn btn-error btn-sm",
                        data: {
                          controller: "undo-delete",
                          action: "click->undo-delete#submit",
                          turbo_method: :delete,
                          undo_delete_url_value: pesticide_path(pesticide.id),
                          undo_delete_message_value: t('pesticides.undo.toast', name: pesticide.name)
                        } %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <div class="empty-state-icon"><%= t('.empty.icon') %></div>
    <h3><%= t('.empty.title') %></h3>
    <p><%= t('.empty.description') %></p>
  </div>
<% end %>
