<%# app/views/crops/_header.html.erb %>
<%# 作物詳細画面のヘッダー部分 %>
<%#
  パラメータ:
    crop: Crop - 表示する作物オブジェクト
    display: ResourceDisplayCapabilities（Interactor 由来）

  使用例:
    render 'crops/header', crop: @crop, display: @html_display
%>

<div class="crop-detail-header">
  <h1 class="crop-detail-title"><%= crop.name %></h1>
  <% if local_assigns[:display]&.show_reference_badge %>
    <div class="crop-detail-type reference"><%= t('crops.show.reference_crop') %></div>
  <% end %>
</div>
