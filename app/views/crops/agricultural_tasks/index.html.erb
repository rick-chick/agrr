<% content_for :title, "#{@crop.name} - #{t('.title')} - AGRR" %>

<div class="page-header">
  <h1 class="page-title">
    <%= link_to @crop.name, crop_path(@crop), class: "crop-link" %> - <%= t('.title') %>
  </h1>
  <%= link_to t('.new_agricultural_task'), new_crop_agricultural_task_path(@crop), class: "btn btn-success" %>
</div>

<% if @task_template_rows.any? %>
  <div class="agricultural-tasks-grid">
    <% @task_template_rows.each do |row| %>
      <% at = row[:agricultural_task] %>
      <div class="agricultural-task-card">
        <h3 class="agricultural-task-name"><%= row[:name] %></h3>
        <% if row[:description].present? %>
          <div class="agricultural-task-description"><%= truncate(row[:description].to_s, length: 50) %></div>
        <% end %>
        <% if row[:time_per_sqm].present? %>
          <div class="agricultural-task-time">⏱ <%= row[:time_per_sqm] %> h/㎡</div>
        <% end %>
        <% if at.present? && at[:weather_dependency].present? %>
          <div class="agricultural-task-meta">
            🌤 <%= at[:weather_dependency] %>
          </div>
        <% end %>
        <div class="agricultural-task-actions">
          <% if at.present? %>
            <%= link_to t('.actions.show'), agricultural_task_path(at[:id]), class: "btn btn-info btn-sm" %>
          <% end %>
          <%= link_to t('.actions.edit'),
                      edit_crop_agricultural_task_path(@crop, row[:id]),
                      class: "btn btn-secondary btn-sm" %>
          <%= button_to t('.actions.delete'),
                        crop_agricultural_task_path(@crop, row[:id]),
                        method: :delete,
                        data: { turbo_confirm: t('.actions.delete_confirm') },
                        class: "btn btn-danger btn-sm" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <div class="empty-state-icon">🔧</div>
    <h3><%= t('.empty.title') %></h3>
    <p><%= t('.empty.description') %></p>
    <%= link_to t('.empty.button'), new_crop_agricultural_task_path(@crop), class: "btn btn-success" %>
  </div>
<% end %>

<%= link_to t('.back_to_crop'), crop_path(@crop), class: "btn btn-secondary" %>



